## 🏛️ PATRÓN DE MÓDULO DE REFERENCIA

Todo módulo nuevo debe seguir exactamente este patrón (basado en CoursesModule):

### Estructura de archivos
```
src/nombre-modulo/
├── nombre-modulo.module.ts
├── nombre-modulo.controller.ts
├── nombre-modulo.service.ts
└── dto/
    ├── create-nombre.dto.ts
    └── update-nombre.dto.ts
```

### Patrón del Service

```typescript
import { Injectable, NotFoundException, ForbiddenException } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';

@Injectable()
export class NombreService {
  constructor(private readonly prisma: PrismaService) {}

  async findAll(page = 1, limit = 10) {
    const skip = (page - 1) * limit;
    const [items, total] = await Promise.all([
      this.prisma.model.findMany({
        where: { isActive: true },
        select: { id: true, name: true /* nunca password */ },
        skip,
        take: limit,
        orderBy: { createdAt: 'desc' },
      }),
      this.prisma.model.count({ where: { isActive: true } }),
    ]);
    return {
      data: items,
      meta: { total, page, limit, totalPages: Math.ceil(total / limit) },
    };
  }

  async findOne(id: string) {
    const item = await this.prisma.model.findUnique({
      where: { id },
      select: { id: true, name: true },
    });
    if (!item) throw new NotFoundException(`Recurso ${id} no encontrado`);
    return item;
  }

  async remove(id: string) {
    await this.findOne(id); // lanza NotFoundException si no existe
    return this.prisma.model.update({
      where: { id },
      data: { isActive: false }, // soft delete — NUNCA usar delete()
    });
  }
}
```

### Patrón del Controller

```typescript
import { Controller, Get, Post, Patch, Delete, Param, Body, Query, UseGuards, Request } from '@nestjs/common';
import { JwtAuthGuard } from '../auth/jwt-auth.guard';
import { RolesGuard } from '../auth/roles.guard';
import { Roles } from '../auth/roles.decorator';

@Controller('nombre')
@UseGuards(JwtAuthGuard)
export class NombreController {
  constructor(private readonly service: NombreService) {}

  @Get()
  findAll(@Query('page') page = '1', @Query('limit') limit = '10') {
    return this.service.findAll(+page, +limit);
  }

  @Post()
  @UseGuards(RolesGuard)
  @Roles('TEACHER', 'ADMIN')
  create(@Body() dto: CreateNombreDto, @Request() req) {
    return this.service.create(dto, req.user.id);
  }
}
```

### Patrón del DTO

```typescript
import { IsString, IsOptional, IsNumber, Min, Max } from 'class-validator';
import { Transform } from 'class-transformer';

export class CreateNombreDto {
  @IsString()
  @Transform(({ value }) => value?.trim())
  name: string;

  @IsOptional()
  @IsString()
  description?: string;
}
```

