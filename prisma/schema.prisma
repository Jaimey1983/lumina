generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String            @id @default(cuid())
  email                   String            @unique
  password                String
  name                    String
  lastName                String
  role                    Role              @default(STUDENT)
  avatar                  String?
  isActive                Boolean           @default(true)
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt
  institution             String?
  classResults            ClassResult[]
  teacherCourses          Course[]          @relation("TeacherCourses")
  enrollments             Enrollment[]
  gradebookEntries        GradeEntry[]
  messageReads            MessageRead[]
  receivedMessages        Message[]         @relation("ReceivedMessages")
  sentMessages            Message[]         @relation("SentMessages")
  peerEvaluationsReceived PeerEvaluation[]  @relation("EvaluatedUser")
  peerEvaluationsGiven    PeerEvaluation[]  @relation("EvaluatorUser")
  selfEvaluations         SelfEvaluation[]
  studentBadges           StudentBadge[]
  studentPoints           StudentPoints[]
  workGroupMemberships    WorkGroupMember[]

  @@map("users")
}

model Course {
  id                 String              @id @default(cuid())
  name               String
  description        String?
  code               String              @unique
  isActive           Boolean             @default(true)
  teacherId          String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  achievements       Achievement[]
  badges             Badge[]
  classes            Class[]
  teacher            User                @relation("TeacherCourses", fields: [teacherId], references: [id])
  enrollments        Enrollment[]
  forums             Forum[]
  gradebookStructure GradebookStructure?
  messages           Message[]
  periods            Period[]
  studentPoints      StudentPoints[]
  workGroups         WorkGroup[]

  @@map("courses")
}

model Period {
  id           String        @id @default(cuid())
  name         String
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean       @default(true)
  courseId     String
  createdAt    DateTime      @default(now())
  achievements Achievement[]
  gradeEntries GradeEntry[]
  course       Course        @relation(fields: [courseId], references: [id])

  @@map("periods")
}

model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@map("enrollments")
}

model Class {
  id                 String              @id @default(cuid())
  title              String
  description        String?
  code               String              @unique
  status             ClassStatus         @default(DRAFT)
  courseId           String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  desempeno          Json?
  codigo             String              @unique @default(cuid())
  results            ClassResult[]
  sessions           ClassSession[]
  course             Course              @relation(fields: [courseId], references: [id])
  collabNotes        CollabNote[]
  slides             Slide[]
  whiteboardSessions WhiteboardSession[]

  @@map("classes")
}

model Slide {
  id        String    @id @default(cuid())
  order     Int
  type      SlideType
  title     String
  content   Json?
  classId   String
  createdAt DateTime  @default(now())
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("slides")
}

model ClassSession {
  id          String        @id @default(cuid())
  classId     String
  startedAt   DateTime      @default(now())
  endedAt     DateTime?
  activeSlide Int           @default(0)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  results     ClassResult[]

  @@map("class_sessions")
}

model ClassResult {
  id           String        @id @default(cuid())
  classId      String
  studentId    String
  slideId      String
  activityType String
  score        Float         @default(0)
  maxScore     Float         @default(1)
  isManual     Boolean       @default(false)
  response     Json?
  sessionId    String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  class        Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  student      User          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  session      ClassSession? @relation(fields: [sessionId], references: [id])

  @@unique([classId, studentId, slideId])
  @@map("class_results")
}

model GradebookStructure {
  id       String   @id @default(cuid())
  courseId String   @unique
  aspects  Aspect[]
  course   Course   @relation(fields: [courseId], references: [id])

  @@map("gradebook_structures")
}

model Aspect {
  id           String             @id @default(cuid())
  name         String
  weight       Float
  structureId  String
  achievements Achievement[]
  structure    GradebookStructure @relation(fields: [structureId], references: [id])

  @@map("aspects")
}

model Achievement {
  id                    String                 @id @default(cuid())
  code                  String
  statement             String
  scope                 AchievementScope       @default(SPECIFIC)
  courseId              String
  aspectId              String
  periodId              String
  createdAt             DateTime               @default(now())
  aspect                Aspect                 @relation(fields: [aspectId], references: [id])
  course                Course                 @relation(fields: [courseId], references: [id])
  period                Period                 @relation(fields: [periodId], references: [id])
  performanceIndicators PerformanceIndicator[]

  @@unique([code, courseId])
  @@map("achievements")
}

model PerformanceIndicator {
  id              String          @id @default(cuid())
  statement       String
  competenceType  CompetenceType
  competenceScope CompetenceScope @default(GENERAL)
  subject         String?
  weight          Float
  achievementId   String
  createdAt       DateTime        @default(now())
  activities      Activity[]
  achievement     Achievement     @relation(fields: [achievementId], references: [id])

  @@map("performance_indicators")
}

model Activity {
  id                     String               @id @default(cuid())
  name                   String
  weight                 Float
  maxScore               Float                @default(5.0)
  performanceIndicatorId String
  performanceIndicator   PerformanceIndicator @relation(fields: [performanceIndicatorId], references: [id])
  gradeEntries           GradeEntry[]
  groupActivities        GroupActivity[]

  @@map("activities")
}

model GradeEntry {
  id         String   @id @default(cuid())
  score      Float
  feedback   String?
  userId     String
  activityId String
  periodId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  activity   Activity @relation(fields: [activityId], references: [id])
  period     Period   @relation(fields: [periodId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, activityId, periodId])
  @@map("grade_entries")
}

model SelfEvaluation {
  id        String   @id @default(cuid())
  score     Float
  feedback  String?
  userId    String
  courseId  String
  periodId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId, periodId])
  @@map("self_evaluations")
}

model PeerEvaluation {
  id          String   @id @default(cuid())
  score       Float
  feedback    String?
  evaluatorId String
  evaluatedId String
  courseId    String
  periodId    String
  createdAt   DateTime @default(now())
  evaluated   User     @relation("EvaluatedUser", fields: [evaluatedId], references: [id])
  evaluator   User     @relation("EvaluatorUser", fields: [evaluatorId], references: [id])

  @@unique([evaluatorId, evaluatedId, courseId, periodId])
  @@map("peer_evaluations")
}

model StudentPoints {
  id        String   @id @default(cuid())
  points    Int      @default(0)
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  reason    String?
  course    Course   @relation(fields: [courseId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
  @@map("student_points")
}

model Badge {
  id          String         @id @default(cuid())
  name        String
  description String?
  icon        String?
  isActive    Boolean        @default(true)
  courseId    String
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  course      Course         @relation(fields: [courseId], references: [id])
  assignments StudentBadge[]

  @@map("badges")
}

model StudentBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, badgeId])
  @@map("student_badges")
}

model Message {
  id          String        @id @default(cuid())
  content     String
  isDeleted   Boolean       @default(false)
  courseId    String
  senderId    String
  recipientId String?
  parentId    String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  reads       MessageRead[]
  course      Course        @relation(fields: [courseId], references: [id])
  parent      Message?      @relation("MessageReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies     Message[]     @relation("MessageReplies")
  recipient   User?         @relation("ReceivedMessages", fields: [recipientId], references: [id])
  sender      User          @relation("SentMessages", fields: [senderId], references: [id])

  @@map("messages")
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())
  message   Message  @relation(fields: [messageId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_reads")
}

model Webhook {
  id          String       @id @default(cuid())
  name        String
  url         String
  secret      String?
  events      String[]
  isActive    Boolean      @default(true)
  courseId    String?
  createdById String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  logs        WebhookLog[]

  @@map("webhooks")
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  statusCode Int?
  response   String?
  success    Boolean
  sentAt     DateTime @default(now())
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

model Forum {
  id          String        @id @default(cuid())
  name        String
  description String?
  isActive    Boolean       @default(true)
  courseId    String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  threads     ForumThread[]
  course      Course        @relation(fields: [courseId], references: [id])

  @@map("forums")
}

model ForumThread {
  id        String       @id @default(cuid())
  title     String
  body      String
  isPinned  Boolean      @default(false)
  isLocked  Boolean      @default(false)
  isActive  Boolean      @default(true)
  forumId   String
  authorId  String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  replies   ForumReply[]
  forum     Forum        @relation(fields: [forumId], references: [id], onDelete: Cascade)

  @@map("forum_threads")
}

model ForumReply {
  id        String      @id @default(cuid())
  body      String
  isActive  Boolean     @default(true)
  threadId  String
  authorId  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@map("forum_replies")
}

model WhiteboardSession {
  id          String   @id @default(cuid())
  name        String
  content     Json?
  isActive    Boolean  @default(true)
  classId     String
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("whiteboard_sessions")
}

model CollabNote {
  id          String        @id @default(cuid())
  title       String
  content     Json?
  isActive    Boolean       @default(true)
  classId     String
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  versions    NoteVersion[]

  @@map("collab_notes")
}

model NoteVersion {
  id        String     @id @default(cuid())
  content   Json
  noteId    String
  authorId  String
  createdAt DateTime   @default(now())
  note      CollabNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@map("note_versions")
}

model WorkGroup {
  id          String            @id @default(cuid())
  name        String
  description String?
  isActive    Boolean           @default(true)
  courseId    String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  activities  GroupActivity[]
  members     WorkGroupMember[]
  course      Course            @relation(fields: [courseId], references: [id])

  @@map("work_groups")
}

model WorkGroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  joinedAt DateTime  @default(now())
  group    WorkGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])

  @@unique([groupId, userId])
  @@map("work_group_members")
}

model GroupActivity {
  id         String    @id @default(cuid())
  groupId    String
  activityId String
  assignedAt DateTime  @default(now())
  activity   Activity  @relation(fields: [activityId], references: [id])
  group      WorkGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([groupId, activityId])
  @@map("group_activities")
}

enum Role {
  SUPERADMIN
  ADMIN
  DEPARTMENT_HEAD
  TEACHER
  TEACHER_ASSISTANT
  STUDENT
  PARENT
  GUEST
}

enum ClassStatus {
  DRAFT
  PUBLISHED
  LIVE
  ARCHIVED
}

enum SlideType {
  COVER
  CONTENT
  ACTIVITY
  VIDEO
  IMAGE
}

enum AchievementScope {
  SPECIFIC
  SUBJECT
  GENERAL
}

enum CompetenceType {
  COGNITIVE
  METHODOLOGICAL
  INTERPERSONAL
  INSTRUMENTAL
  SUBJECT_SPECIFIC
}

enum CompetenceScope {
  GENERAL
  SPECIFIC
}
