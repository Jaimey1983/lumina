generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIOS ─────────────────────────────────────────────
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  name        String
  lastName    String
  role        Role     @default(STUDENT)
  avatar      String?
  institution String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  teacherCourses    Course[]        @relation("TeacherCourses")
  enrollments       Enrollment[]
  gradebookEntries  GradeEntry[]
  selfEvaluations   SelfEvaluation[]
  peerEvaluationsGiven    PeerEvaluation[] @relation("EvaluatorUser")
  peerEvaluationsReceived PeerEvaluation[] @relation("EvaluatedUser")
  studentPoints     StudentPoints[]
  studentBadges     StudentBadge[]
  sentMessages      Message[]       @relation("SentMessages")
  receivedMessages  Message[]       @relation("ReceivedMessages")
  messageReads      MessageRead[]
  workGroupMemberships WorkGroupMember[]

  @@map("users")
}

enum Role {
  SUPERADMIN
  ADMIN
  DEPARTMENT_HEAD
  TEACHER
  TEACHER_ASSISTANT
  STUDENT
  PARENT
  GUEST
}

// ─── CURSOS ────────────────────────────────────────────────
model Course {
  id          String   @id @default(cuid())
  name        String
  description String?
  code        String   @unique
  isActive    Boolean  @default(true)
  teacherId   String
  teacher     User     @relation("TeacherCourses", fields: [teacherId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  enrollments         Enrollment[]
  classes             Class[]
  gradebookStructure  GradebookStructure?
  periods             Period[]
  studentPoints       StudentPoints[]
  badges              Badge[]
  messages            Message[]
  workGroups          WorkGroup[]
  forums              Forum[]

  @@map("courses")
}

// ─── PERÍODOS ACADÉMICOS ───────────────────────────────────
model Period {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  gradeEntries GradeEntry[]

  @@map("periods")
}

// ─── MATRÍCULAS ────────────────────────────────────────────
model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@map("enrollments")
}

// ─── CLASES ────────────────────────────────────────────────
model Class {
  id          String      @id @default(cuid())
  title       String
  description String?
  code        String      @unique
  status      ClassStatus @default(DRAFT)
  courseId    String
  course      Course      @relation(fields: [courseId], references: [id])
  slides             Slide[]
  whiteboardSessions WhiteboardSession[]
  collabNotes        CollabNote[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("classes")
}

enum ClassStatus {
  DRAFT
  PUBLISHED
  LIVE
  ARCHIVED
}

// ─── SLIDES ────────────────────────────────────────────────
model Slide {
  id        String    @id @default(cuid())
  order     Int
  type      SlideType
  title     String
  content   Json?
  classId   String
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@map("slides")
}

enum SlideType {
  COVER
  CONTENT
  ACTIVITY
  VIDEO
  IMAGE
}

// ─── SISTEMA DE CALIFICACIÓN ───────────────────────────────
model GradebookStructure {
  id       String   @id @default(cuid())
  courseId String   @unique
  course   Course   @relation(fields: [courseId], references: [id])
  aspects  Aspect[]

  @@map("gradebook_structures")
}

model Aspect {
  id           String             @id @default(cuid())
  name         String
  weight       Float
  structureId  String
  structure    GradebookStructure @relation(fields: [structureId], references: [id])
  indicators   Indicator[]

  @@map("aspects")
}

model Indicator {
  id         String      @id @default(cuid())
  name       String
  weight     Float
  aspectId   String
  aspect     Aspect      @relation(fields: [aspectId], references: [id])
  activities Activity[]

  @@map("indicators")
}

model Activity {
  id           String         @id @default(cuid())
  name         String
  weight       Float
  maxScore     Float          @default(5.0)
  indicatorId  String
  indicator    Indicator      @relation(fields: [indicatorId], references: [id])
  gradeEntries GradeEntry[]
  groupActivities GroupActivity[]

  @@map("activities")
}

// ─── NOTAS ─────────────────────────────────────────────────
model GradeEntry {
  id         String   @id @default(cuid())
  score      Float
  feedback   String?
  userId     String
  activityId String
  periodId   String
  user       User     @relation(fields: [userId], references: [id])
  activity   Activity @relation(fields: [activityId], references: [id])
  period     Period   @relation(fields: [periodId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, activityId, periodId])
  @@map("grade_entries")
}

// ─── AUTOEVALUACIÓN ────────────────────────────────────────
model SelfEvaluation {
  id        String   @id @default(cuid())
  score     Float
  feedback  String?
  userId    String
  courseId  String
  periodId  String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, courseId, periodId])
  @@map("self_evaluations")
}

// ─── COEVALUACIÓN ──────────────────────────────────────────
model PeerEvaluation {
  id          String   @id @default(cuid())
  score       Float
  feedback    String?
  evaluatorId String
  evaluatedId String
  courseId    String
  periodId    String
  evaluator   User     @relation("EvaluatorUser", fields: [evaluatorId], references: [id])
  evaluated   User     @relation("EvaluatedUser", fields: [evaluatedId], references: [id])
  createdAt   DateTime @default(now())

  @@unique([evaluatorId, evaluatedId, courseId, periodId])
  @@map("peer_evaluations")
}

// ─── GAMIFICACIÓN ─────────────────────────────────────────
model StudentPoints {
  id        String   @id @default(cuid())
  points    Int      @default(0)
  reason    String?
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, courseId])
  @@map("student_points")
}

model Badge {
  id          String         @id @default(cuid())
  name        String
  description String?
  icon        String?
  isActive    Boolean        @default(true)
  courseId    String
  course      Course         @relation(fields: [courseId], references: [id])
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  assignments StudentBadge[]

  @@map("badges")
}

model StudentBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  user      User     @relation(fields: [userId], references: [id])
  badge     Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)
  awardedAt DateTime @default(now())

  @@unique([userId, badgeId])
  @@map("student_badges")
}

// ─── MENSAJERÍA ────────────────────────────────────────────
model Message {
  id          String    @id @default(cuid())
  content     String
  isDeleted   Boolean   @default(false)
  courseId    String
  senderId    String
  recipientId String?
  parentId    String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course    Course        @relation(fields: [courseId], references: [id])
  sender    User          @relation("SentMessages", fields: [senderId], references: [id])
  recipient User?         @relation("ReceivedMessages", fields: [recipientId], references: [id])
  parent    Message?      @relation("MessageReplies", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   Message[]     @relation("MessageReplies")
  reads     MessageRead[]

  @@map("messages")
}

model MessageRead {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  readAt    DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("message_reads")
}

// ─── INTEGRACIONES / WEBHOOKS ─────────────────────────────

model Webhook {
  id        String       @id @default(cuid())
  name      String
  url       String
  secret    String?      // HMAC-SHA256 signing secret opcional
  events    String[]     // lista de eventos suscritos
  isActive  Boolean      @default(true)
  courseId  String?      // null = webhook global (solo ADMIN/SUPERADMIN)
  createdById String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  logs      WebhookLog[]

  @@map("webhooks")
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  statusCode Int?
  response   String?
  success    Boolean
  sentAt     DateTime @default(now())
  webhook    Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@map("webhook_logs")
}

// ─── FOROS ────────────────────────────────────────────────

model Forum {
  id          String        @id @default(cuid())
  name        String
  description String?
  isActive    Boolean       @default(true)
  courseId    String
  course      Course        @relation(fields: [courseId], references: [id])
  threads     ForumThread[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("forums")
}

model ForumThread {
  id        String       @id @default(cuid())
  title     String
  body      String
  isPinned  Boolean      @default(false)
  isLocked  Boolean      @default(false)
  isActive  Boolean      @default(true)
  forumId   String
  authorId  String
  forum     Forum        @relation(fields: [forumId], references: [id], onDelete: Cascade)
  replies   ForumReply[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@map("forum_threads")
}

model ForumReply {
  id        String      @id @default(cuid())
  body      String
  isActive  Boolean     @default(true)
  threadId  String
  authorId  String
  thread    ForumThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("forum_replies")
}

// ─── COLABORACIÓN ──────────────────────────────────────────

model WhiteboardSession {
  id          String   @id @default(cuid())
  name        String
  content     Json?    // Estado canvas Fabric.js
  isActive    Boolean  @default(true)
  classId     String
  createdById String
  class       Class    @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("whiteboard_sessions")
}

model CollabNote {
  id          String        @id @default(cuid())
  title       String
  content     Json?         // Documento Tiptap JSON
  isActive    Boolean       @default(true)
  classId     String
  createdById String
  class       Class         @relation(fields: [classId], references: [id], onDelete: Cascade)
  versions    NoteVersion[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@map("collab_notes")
}

model NoteVersion {
  id        String     @id @default(cuid())
  content   Json       // Snapshot del contenido Tiptap
  noteId    String
  authorId  String
  note      CollabNote @relation(fields: [noteId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@map("note_versions")
}

model WorkGroup {
  id          String            @id @default(cuid())
  name        String
  description String?
  isActive    Boolean           @default(true)
  courseId    String
  course      Course            @relation(fields: [courseId], references: [id])
  members     WorkGroupMember[]
  activities  GroupActivity[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("work_groups")
}

model WorkGroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  group    WorkGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id])
  joinedAt DateTime  @default(now())

  @@unique([groupId, userId])
  @@map("work_group_members")
}

model GroupActivity {
  id         String    @id @default(cuid())
  groupId    String
  activityId String
  group      WorkGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  activity   Activity  @relation(fields: [activityId], references: [id])
  assignedAt DateTime  @default(now())

  @@unique([groupId, activityId])
  @@map("group_activities")
}