### Patrón del Service

```typescript
import { Injectable, NotFoundException, ForbiddenException } from '@nestjs/common';
import { PrismaService } from '../prisma/prisma.service';

@Injectable()
export class NombreService {
  constructor(private readonly prisma: PrismaService) {}

  async findAll(page = 1, limit = 10) {
    const skip = (page - 1) * limit;
    const [items, total] = await Promise.all([
      this.prisma.model.findMany({
        where: { isActive: true },
        select: { id: true, name: true /* nunca password */ },
        skip,
        take: limit,
        orderBy: { createdAt: 'desc' },
      }),
      this.prisma.model.count({ where: { isActive: true } }),
    ]);
    return {
      data: items,
      meta: { total, page, limit, totalPages: Math.ceil(total / limit) },
    };
  }

  async findOne(id: string) {
    const item = await this.prisma.model.findUnique({
      where: { id },
      select: { id: true, name: true },
    });
    if (!item) throw new NotFoundException(`Recurso ${id} no encontrado`);
    return item;
  }

  async remove(id: string) {
    await this.findOne(id); // lanza NotFoundException si no existe
    return this.prisma.model.update({
      where: { id },
      data: { isActive: false }, // soft delete — NUNCA usar delete()
    });
  }
}
```

