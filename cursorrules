  type      SlideType
  title     String
  content   Json?
  classId   String
  class     Class     @relation(fields: [classId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@map("slides")
}

enum SlideType {
  COVER
  CONTENT
  ACTIVITY
  VIDEO
  IMAGE
}

// ─── SISTEMA DE CALIFICACIÓN ───────────────────────────────
model GradebookStructure {
