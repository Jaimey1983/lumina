model Period {
  id        String   @id @default(cuid())
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean  @default(true)
  courseId  String
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  gradeEntries GradeEntry[]

  @@map("periods")
}

// ─── MATRÍCULAS ────────────────────────────────────────────
model Enrollment {
  id        String   @id @default(cuid())
  userId    String
  courseId  String
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, courseId])
  @@map("enrollments")
}

// ─── CLASES ────────────────────────────────────────────────
model Class {
  id          String      @id @default(cuid())
  title       String
  description String?
  code        String      @unique
  status      ClassStatus @default(DRAFT)
  courseId    String
  course      Course      @relation(fields: [courseId], references: [id])
  slides      Slide[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@map("classes")
}

enum ClassStatus {
  DRAFT
  PUBLISHED
  LIVE
